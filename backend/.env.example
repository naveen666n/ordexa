# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=product_catalog_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT (use long random strings — minimum 32 characters)
JWT_ACCESS_SECRET=replace_with_random_64_char_string_here_minimum_32_chars
JWT_REFRESH_SECRET=replace_with_different_random_64_char_string_minimum_32
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption (must be exactly 64 hex characters = 32 bytes)
ENCRYPTION_KEY=replace_with_exactly_64_hex_chars_for_aes256_encryption_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# App
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
