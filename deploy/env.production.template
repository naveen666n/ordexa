# ── PRODUCTION ENVIRONMENT VARIABLES ─────────────────────────────────────────
# Copy this file to /var/www/product-catalog/backend/.env on the EC2 instance
# Fill in ALL values before starting the server

NODE_ENV=production
PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=catalog_user
DB_PASSWORD=CHANGE_ME_strong_db_password
DB_NAME=product_catalog_prod

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_ACCESS_SECRET=CHANGE_ME_replace_with_96_hex_char_random_string_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_replace_with_different_96_hex_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Encryption (AES-256) ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32   (output is 64 hex chars)
ENCRYPTION_KEY=CHANGE_ME_exactly_64_hex_chars_for_aes256_key

# ── Google OAuth (leave blank to disable) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://YOUR_DOMAIN/api/v1/auth/google/callback

# ── Razorpay ──────────────────────────────────────────────────────────────────
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=CHANGE_ME_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_razorpay_webhook_secret

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://YOUR_DOMAIN
ALLOWED_ORIGINS=https://YOUR_DOMAIN
UPLOAD_DIR=/var/uploads
MAX_FILE_SIZE=10485760
INVENTORY_BLOCKING_ENABLED=true
